# ============================================================
# .env.example — Sistema 1: Extrator de Leads INPI
# ============================================================
# COPIE este arquivo para .env e preencha com SEUS dados.
# NUNCA commite o .env real no Git.
# ============================================================

# --- Banco de Dados ---
# SQLite (dev): deixe vazio, usará ./data/leads.db
# PostgreSQL (prod): preencha a connection string
DATABASE_URL=

# --- INPI (Contas para RPA do pePI) ---
# Formato: login:senha (separar múltiplas contas por vírgula)
# Ex: usuario1:senha1,usuario2:senha2
INPI_CONTAS=

# --- Anti-CAPTCHA ---
# CapMonster: https://capmonster.cloud/
CAPMONSTER_API_KEY=

# --- Proxy Residencial (opcional, recomendado) ---
# Ex: http://user:pass@proxy.brightdata.com:22225
PROXY_URL=

# --- API de Enriquecimento CNPJ (escolher uma) ---
# InfoSimples: https://infosimples.com/
INFOSIMPLES_TOKEN=

# --- Caminhos ---
# Pasta onde os XMLs temporários ficam
TEMP_DIR=.tmp
# Pasta onde as planilhas finais são salvas
OUTPUT_DIR=output
